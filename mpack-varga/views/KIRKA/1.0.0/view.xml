<view>
  <name>KIRKA</name>
  <label>Kirka</label>
  <version>1.0.0</version>
  <description>Dashboard for monitoring and managing the Kirka distributed task scheduler.</description>
  <min-ambari-version>2.7.0</min-ambari-version>

  <parameter>
    <name>kirka.service.url</name>
    <description>Base URL of the Kirka Server (e.g. http://kirka-host:8080)</description>
    <label>Kirka Server URL</label>
    <placeholder>http://localhost:8080</placeholder>
    <required>true</required>
  </parameter>

  <parameter>
    <name>kirka.security.enabled</name>
    <description>Whether security (Kerberos/SPNEGO) is enabled on the Kirka Server</description>
    <label>Security Enabled</label>
    <default-value>false</default-value>
    <required>false</required>
  </parameter>

  <parameter>
    <name>kirka.hbase.zk.quorum</name>
    <description>HBase ZooKeeper Quorum</description>
    <label>HBase ZK Quorum</label>
    <required>false</required>
  </parameter>

  <parameter>
    <name>kirka.hdfs.uri</name>
    <description>HDFS URI</description>
    <label>HDFS URI</label>
    <required>false</required>
  </parameter>

  <parameter>
    <name>kirka.kerberos.enabled</name>
    <description>Whether Kerberos is enabled</description>
    <label>Kerberos Enabled</label>
    <default-value>false</default-value>
    <required>false</required>
  </parameter>

  <parameter>
    <name>kirka.ranger.admin.url</name>
    <description>Ranger Admin URL</description>
    <label>Ranger Admin URL</label>
    <required>false</required>
  </parameter>

  <parameter>
    <name>kirka.logging.level</name>
    <description>Logging level for Kirka</description>
    <label>Log Level</label>
    <default-value>INFO</default-value>
    <required>false</required>
  </parameter>

  <auto-instance>
    <name>AUTO_KIRKA_INSTANCE</name>
    <label>Kirka</label>
    <description>Auto-created instance linked to the Kirka service</description>
    <stack-id>ODP-1.3</stack-id>
    <services>
      <service>
        <name>KIRKA</name>
      </service>
    </services>
    <property>
      <key>kirka.service.url</key>
      <value>http://${KIRKA_SERVER_HOST}:${kirka-site/kirka.port}</value>
    </property>
    <property>
      <key>kirka.security.enabled</key>
      <value>${kirka-site/security.enabled}</value>
    </property>
    <property>
      <key>kirka.hbase.zk.quorum</key>
      <value>${kirka-site/hbase.zookeeper.quorum}</value>
    </property>
    <property>
      <key>kirka.hdfs.uri</key>
      <value>${kirka-site/hadoop.hdfs.uri}</value>
    </property>
    <property>
      <key>kirka.kerberos.enabled</key>
      <value>${kirka-site/security.kerberos.enabled}</value>
    </property>
    <property>
      <key>kirka.ranger.admin.url</key>
      <value>${kirka-site/ranger.admin.url}</value>
    </property>
    <property>
      <key>kirka.logging.level</key>
      <value>${kirka-site/logging.level.kirka}</value>
    </property>
  </auto-instance>
</view>
